APP_NAME=stock-market-agent
ENVIRONMENT=local

AWS_REGION=eu-west-2
REPORTS_BUCKET=
OPENSEARCH_ENDPOINT=
OPENSEARCH_INDEX=financial-report-chunks

# Local development uses SQLite. AWS production uses RDS PostgreSQL.
DATABASE_HOST=
DATABASE_PORT=5432
DATABASE_NAME=stockagent
DATABASE_USERNAME=
DATABASE_PASSWORD=
DATABASE_SECRET_ARN=
CHAT_HISTORY_DB_PATH=data/chat_history.sqlite3

# Shared MCP server for all projects.
# The current common MCP server uses SSE transport.
# Host port 8001 is used because port 8000 is already used by another local app.
MCP_SERVER_URL=http://localhost:8001/sse
MCP_API_KEY=

# Optional Bedrock model IDs.
BEDROCK_CHAT_MODEL_ID=amazon.nova-lite-v1:0
BEDROCK_EMBEDDING_MODEL_ID=amazon.titan-embed-text-v2:0

# Optional observability.
LANGFUSE_ENABLED=false
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_BASE_URL=https://cloud.langfuse.com
LANGFUSE_FLUSH_ON_REQUEST=false

# RAG evaluation.
RAGAS_ENABLED=true
RAGAS_SCORE_PREFIX=ragas
RAGAS_MIN_CONTEXT_PRECISION=0.45
RAGAS_MIN_FAITHFULNESS=0.55

# Observability dashboard and prompt catalogue.
OBSERVABILITY_METRICS_PATH=data/observability_metrics.jsonl
PROMPT_CATALOG_PATH=data/prompts/prompts.json
ACTIVE_PROMPT_ENVIRONMENT=production
