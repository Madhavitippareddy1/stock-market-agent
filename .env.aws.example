APP_NAME=stock-market-agent
ENVIRONMENT=aws

AWS_REGION=eu-west-2

# Bedrock model configuration.
BEDROCK_CHAT_MODEL_ID=amazon.nova-lite-v1:0
BEDROCK_EMBEDDING_MODEL_ID=amazon.titan-embed-text-v2:0

# AWS RAG resources.
REPORTS_BUCKET=
OPENSEARCH_ENDPOINT=
OPENSEARCH_INDEX=financial-report-chunks

# AWS database resources.
DATABASE_HOST=
DATABASE_PORT=5432
DATABASE_NAME=stockagent
DATABASE_USERNAME=
DATABASE_PASSWORD=
DATABASE_SECRET_ARN=
CHAT_HISTORY_DB_PATH=data/chat_history.sqlite3

# AWS-hosted common MCP server.
# Replace this with the ECS public DNS, ALB URL, or API Gateway URL.
# Example with ECS public IP:
# MCP_SERVER_URL=http://<aws-mcp-public-ip>:8000/sse
# Example with ALB:
# MCP_SERVER_URL=http://<aws-mcp-load-balancer-dns>/sse
MCP_SERVER_URL=http://16.60.156.10:8000/sse
MCP_API_KEY=

# Observability.
LANGFUSE_ENABLED=false
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_BASE_URL=https://cloud.langfuse.com
LANGFUSE_FLUSH_ON_REQUEST=false

# RAG evaluation.
RAGAS_ENABLED=true
RAGAS_SCORE_PREFIX=ragas
RAGAS_MIN_CONTEXT_PRECISION=0.45
RAGAS_MIN_FAITHFULNESS=0.55

# Observability dashboard and prompt catalogue.
OBSERVABILITY_METRICS_PATH=data/observability_metrics.jsonl
PROMPT_CATALOG_PATH=data/prompts/prompts.json
ACTIVE_PROMPT_ENVIRONMENT=production
